{
  "name": "wopr",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "bin": {
    "wopr": "./src/main.ts"
  },
  "scripts": {
    "dev": "bun run src/main.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "build": "bun build --compile --define WOPR_VERSION=\"'$(node -p \"require('./package.json').version')\"'\" src/main.ts --outfile wopr"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "^0.80.7",
    "@earendil-works/pi-ai": "^0.80.7",
    "@earendil-works/pi-coding-agent": "^0.80.7",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opentui/core": "0.3.0",
    "typebox": "^1.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "5.9.3"
  }
}
